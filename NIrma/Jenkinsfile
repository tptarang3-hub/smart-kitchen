pipeline {
    agent any

    stages {

        stage('Install pip') {
            steps {
                sh '''
                curl https://bootstrap.pypa.io/get-pip.py -o get-pip.py
                python3 get-pip.py
                '''
            }
        }

        stage('Install Python Dependencies') {
            steps {
                sh '''
                python3 --version
                pip3 install flask
                '''
            }
        }

        stage('Run Application') {
            steps {
                sh '''
                nohup python3 NIrma/app.py &
                '''
            }
        }

    }
}
