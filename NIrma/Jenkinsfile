pipeline {
    agent any

    stages {

        stage('Install Python Dependencies') {
            steps {
                sh '''
                python3 --version
                pip3 install flask --break-system-packages
                '''
            }
        }

        stage('Run Application') {
            steps {
                sh '''
                nohup python3 NIrma/app.py &
                '''
            }
        }

    }
}
